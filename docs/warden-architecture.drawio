<mxfile host="app.diagrams.net" agent="Warden H0" version="24.0.0">
  <diagram name="Warden architecture" id="warden-arch-1">
    <mxGraphModel dx="1400" dy="820" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1300" pageHeight="540" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Warden — pre-execution business-authority PDP + tamper-evident ledger, on Amazon Aurora DSQL · Vercel" style="text;html=1;align=left;verticalAlign=middle;fontSize=15;fontStyle=1;fontColor=#14171A;" vertex="1" parent="1">
          <mxGeometry x="40" y="24" width="980" height="30" as="geometry" />
        </mxCell>

        <mxCell id="agent" value="AI agent fleet — any framework&lt;br&gt;SAP Joule · Oracle · LangGraph ·&lt;br&gt;a real LLM agent (see page 2)" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#232F3E;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.users;" vertex="1" parent="1">
          <mxGeometry x="50" y="250" width="78" height="78" as="geometry" />
        </mxCell>

        <mxCell id="sdk" value="@warden/sdk&lt;br&gt;decide()" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFFFFF;strokeColor=#232F3E;fontColor=#14171A;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="180" y="262" width="120" height="54" as="geometry" />
        </mxCell>

        <mxCell id="vbox" value="Vercel — Warden PDP&#10;(Next.js route handlers · Node runtime)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#F4F4F4;strokeColor=#000000;fontColor=#14171A;fontSize=12;fontStyle=1;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="350" y="170" width="270" height="250" as="geometry" />
        </mxCell>
        <mxCell id="pdp" value="POST /api/pdp/decide&lt;br&gt;→ allow · deny · escalate (+ reason, + rule ids)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFFFFF;strokeColor=#6E1D24;fontColor=#14171A;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="368" y="220" width="234" height="48" as="geometry" />
        </mxCell>
        <mxCell id="engine" value="Engine (one transaction, withRetry)&lt;br&gt;&lt;br&gt;• authority grants — resolved up the org hierarchy&lt;br&gt;• approval limits — escalate to covering ancestor&lt;br&gt;• segregation of duties — over prior-action history&lt;br&gt;• seal verdict → hash-chained ledger" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#FFFFFF;strokeColor=#232F3E;fontColor=#14171A;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="368" y="280" width="234" height="126" as="geometry" />
        </mxCell>

        <mxCell id="region" value="Amazon Aurora DSQL — multi-region cluster (US region set) · active-active · strongly consistent" style="sketch=0;outlineConnect=0;gradientColor=none;html=1;whiteSpace=wrap;fontSize=12;fontStyle=0;container=0;pointerEvents=0;collapsible=0;recursiveResize=0;shape=mxgraph.aws4.group;grIcon=mxgraph.aws4.group_region;strokeColor=#00A4A6;fillColor=none;verticalAlign=top;align=left;spacingLeft=30;fontColor=#147EBA;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="690" y="120" width="500" height="330" as="geometry" />
        </mxCell>
        <mxCell id="dsqlA" value="Aurora DSQL&lt;br&gt;us-east-1 (active)" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=#4D72F3;gradientDirection=north;fillColor=#3334B9;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.aurora;" vertex="1" parent="1">
          <mxGeometry x="740" y="190" width="78" height="78" as="geometry" />
        </mxCell>
        <mxCell id="dsqlB" value="Aurora DSQL&lt;br&gt;us-west-2 (active)" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=#4D72F3;gradientDirection=north;fillColor=#3334B9;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.aurora;" vertex="1" parent="1">
          <mxGeometry x="1052" y="190" width="78" height="78" as="geometry" />
        </mxCell>
        <mxCell id="witness" value="witness&lt;br&gt;us-east-2 (commit quorum)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFFFFF;strokeColor=#00A4A6;fontColor=#14171A;fontSize=11;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="880" y="300" width="130" height="50" as="geometry" />
        </mxCell>
        <mxCell id="tables" value="tables (no FK · client UUIDs · CREATE INDEX ASYNC): org_units · authority_grants · policy_rules · decisions · ledger (hash-chained, append-only)" style="text;html=1;align=center;verticalAlign=middle;fontSize=10;fontColor=#565D63;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="710" y="368" width="460" height="40" as="geometry" />
        </mxCell>

        <mxCell id="callout" value="⊘  Revoke an authority in us-east-1 → the next decision in us-west-2 is denied instantly. No stale read ever approves a revoked grant — the property only synchronous, active-active strong consistency makes buildable." style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#FBEAEA;strokeColor=#B0271F;fontColor=#B0271F;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="350" y="450" width="840" height="46" as="geometry" />
        </mxCell>

        <mxCell id="e1" value="POST proposed action" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=10;endArrow=block;strokeColor=#232F3E;" edge="1" parent="1" source="agent" target="sdk">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#232F3E;" edge="1" parent="1" source="sdk" target="pdp">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" value="evaluate · FOR UPDATE grant · seal verdict (one txn)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=10;endArrow=block;strokeColor=#6E1D24;strokeWidth=2;" edge="1" parent="1" source="engine" target="dsqlA">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" value="synchronous · strongly consistent&lt;br&gt;zero replication lag on commit" style="html=1;fontSize=10;startArrow=block;endArrow=block;strokeColor=#00A4A6;strokeWidth=2;dashed=1;" edge="1" parent="1" source="dsqlA" target="dsqlB">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="Demo flow — agent tab and Warden tab" id="warden-demo-1">
    <mxGraphModel dx="1400" dy="820" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1360" pageHeight="500" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="t2title" value="Demo — two tabs, one contract: a real LLM agent (left) governed by Warden (right)" style="text;html=1;align=left;verticalAlign=middle;fontSize=15;fontStyle=1;fontColor=#14171A;" vertex="1" parent="1"><mxGeometry x="40" y="22" width="1000" height="30" as="geometry" /></mxCell>

        <mxCell id="t2gw" value="Vercel AI Gateway → Anthropic Claude Sonnet 4.6" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#14171A;strokeColor=#000000;fontColor=#FFFFFF;fontSize=11;" vertex="1" parent="1"><mxGeometry x="55" y="92" width="255" height="40" as="geometry" /></mxCell>

        <mxCell id="t2tab1" value="Tab 1 · /agent — agent runtime (a separate app)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#1B1F24;strokeColor=#000000;fontColor=#FFFFFF;fontSize=12;fontStyle=1;verticalAlign=top;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="40" y="158" width="290" height="252" as="geometry" /></mxCell>
        <mxCell id="t2llm" value="LLM agent · ToolLoopAgent&lt;br&gt;reasons, decides which tool to call" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#2A2F36;strokeColor=#3A424B;fontColor=#FFFFFF;fontSize=11;" vertex="1" parent="1"><mxGeometry x="58" y="210" width="254" height="46" as="geometry" /></mxCell>
        <mxCell id="t2tool" value="tool.execute()  →  calls Warden decide() FIRST&lt;br&gt;the action runs ONLY on ALLOW&lt;br&gt;(the LLM never decides the verdict)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#2A2F36;strokeColor=#6E1D24;fontColor=#FFFFFF;fontSize=11;" vertex="1" parent="1"><mxGeometry x="58" y="266" width="254" height="78" as="geometry" /></mxCell>
        <mxCell id="t2actor" value="acts as maya.chen · Crude Desk Agent" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;fontColor=#9AA3AD;" vertex="1" parent="1"><mxGeometry x="62" y="350" width="254" height="24" as="geometry" /></mxCell>

        <mxCell id="t2pdp" value="Warden PDP (Vercel · /api/pdp/decide)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#F4F4F4;strokeColor=#000000;fontColor=#14171A;fontSize=12;fontStyle=1;verticalAlign=top;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="392" y="168" width="262" height="214" as="geometry" /></mxCell>
        <mxCell id="t2engine" value="Engine — one txn, withRetry&lt;br&gt;&lt;br&gt;• grants ↑ org hierarchy&lt;br&gt;• approval limit → escalate&lt;br&gt;• segregation of duties (history)&lt;br&gt;• verdict: allow · deny · escalate + reason&lt;br&gt;• seal verdict → hash-chained ledger" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#FFFFFF;strokeColor=#6E1D24;fontColor=#14171A;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="410" y="220" width="226" height="148" as="geometry" /></mxCell>

        <mxCell id="t2region" value="Amazon Aurora DSQL — multi-region, strongly consistent" style="sketch=0;outlineConnect=0;gradientColor=none;html=1;whiteSpace=wrap;fontSize=11;container=0;pointerEvents=0;collapsible=0;shape=mxgraph.aws4.group;grIcon=mxgraph.aws4.group_region;strokeColor=#00A4A6;fillColor=none;verticalAlign=top;align=left;spacingLeft=30;fontColor=#147EBA;dashed=1;" vertex="1" parent="1"><mxGeometry x="712" y="150" width="338" height="232" as="geometry" /></mxCell>
        <mxCell id="t2dA" value="Aurora DSQL&lt;br&gt;us-east-1" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=#4D72F3;gradientDirection=north;fillColor=#3334B9;strokeColor=#ffffff;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.aurora;" vertex="1" parent="1"><mxGeometry x="752" y="200" width="70" height="70" as="geometry" /></mxCell>
        <mxCell id="t2dB" value="Aurora DSQL&lt;br&gt;us-west-2" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=#4D72F3;gradientDirection=north;fillColor=#3334B9;strokeColor=#ffffff;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=11;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.aurora;" vertex="1" parent="1"><mxGeometry x="940" y="200" width="70" height="70" as="geometry" /></mxCell>
        <mxCell id="t2dnote" value="read grants (FOR UPDATE) · write decision + hash-chained ledger · one txn" style="text;html=1;align=center;verticalAlign=middle;fontSize=10;fontColor=#565D63;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="724" y="318" width="314" height="44" as="geometry" /></mxCell>

        <mxCell id="t2tab2" value="Tab 2 · /console — Warden console" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#EEF1F0;strokeColor=#14171A;fontColor=#14171A;fontSize=12;fontStyle=1;verticalAlign=top;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="1100" y="158" width="220" height="252" as="geometry" /></mxCell>
        <mxCell id="t2cnote" value="the governed decision lands LIVE:&lt;br&gt;&lt;br&gt;• request feed&lt;br&gt;• Decision Inspector&lt;br&gt;• verdict · reason · trace&lt;br&gt;• sealed ledger chain&lt;br&gt;&lt;br&gt;(2.5s live poll)" style="text;html=1;align=left;verticalAlign=top;fontSize=11;fontColor=#14171A;whiteSpace=wrap;spacingLeft=4;" vertex="1" parent="1"><mxGeometry x="1116" y="212" width="190" height="180" as="geometry" /></mxCell>

        <mxCell id="t2nlp" value="NL→policy: describe a control in plain English → Claude Haiku compiles → policy_rule → enforced on the next decision" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#F4EEF0;strokeColor=#6E1D24;fontColor=#6E1D24;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="392" y="398" width="262" height="48" as="geometry" /></mxCell>
        <mxCell id="t2beats" value="capture → ALLOW   ·   settle own deal → DENY SOD-FBO-01   ·   over-limit → ESCALATE   ·   revoke → DENY" style="text;html=1;align=center;verticalAlign=middle;fontSize=10;fontColor=#565D63;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="712" y="404" width="338" height="36" as="geometry" /></mxCell>

        <mxCell id="t2e1" value="reasoning" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;endArrow=block;startArrow=block;strokeColor=#9AA3AD;dashed=1;" edge="1" parent="1" source="t2gw" target="t2llm"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="t2e2" value="POST decide() — pre-execution gate" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;endArrow=block;strokeColor=#6E1D24;strokeWidth=2;" edge="1" parent="1" source="t2tool" target="t2pdp"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="t2e3" value="evaluate · seal verdict (one txn)" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;endArrow=block;strokeColor=#6E1D24;strokeWidth=2;" edge="1" parent="1" source="t2engine" target="t2dA"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="t2e4" value="synchronous&lt;br&gt;strongly consistent" style="html=1;fontSize=9;startArrow=block;endArrow=block;strokeColor=#00A4A6;strokeWidth=2;dashed=1;" edge="1" parent="1" source="t2dA" target="t2dB"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="t2e5" value="verdict → proceed / halt / escalate" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;endArrow=block;strokeColor=#565D63;dashed=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="t2region" target="t2tool"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="t2e6" value="decisions + ledger (poll)" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;endArrow=block;strokeColor=#565D63;dashed=1;" edge="1" parent="1" source="t2region" target="t2tab2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="t2e7" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;strokeColor=#6E1D24;dashed=1;" edge="1" parent="1" source="t2nlp" target="t2engine"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
