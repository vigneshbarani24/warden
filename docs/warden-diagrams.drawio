        <mxCell id="hD" value="Aurora DSQL (decisions + ledger)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;fillColor=#FFFFFF;strokeColor=#147EBA;fontColor=#147EBA;fontSize=12;fontStyle=1;" vertex="1" parent="sx1"><mxGeometry x="980" y="64" width="200" height="44" as="geometry" /></mxCell>

        <mxCell id="lA" style="endArrow=none;dashed=1;html=1;strokeColor=#9AA3A2;" edge="1" parent="sx1"><mxGeometry relative="1" as="geometry"><mxPoint x="155" y="108" as="sourcePoint" /><mxPoint x="155" y="690" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="lP" style="endArrow=none;dashed=1;html=1;strokeColor=#9AA3A2;" edge="1" parent="sx1"><mxGeometry relative="1" as="geometry"><mxPoint x="450" y="108" as="sourcePoint" /><mxPoint x="450" y="690" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="lE" style="endArrow=none;dashed=1;html=1;strokeColor=#9AA3A2;" edge="1" parent="sx1"><mxGeometry relative="1" as="geometry"><mxPoint x="745" y="108" as="sourcePoint" /><mxPoint x="745" y="690" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="lD" style="endArrow=none;dashed=1;html=1;strokeColor=#9AA3A2;" edge="1" parent="sx1"><mxGeometry relative="1" as="geometry"><mxPoint x="1080" y="108" as="sourcePoint" /><mxPoint x="1080" y="690" as="targetPoint" /></mxGeometry></mxCell>

        <mxCell id="b1" value="① a valid trade — ALLOW" style="text;html=1;align=left;fontSize=12;fontStyle=2;fontColor=#1F7A4D;" vertex="1" parent="sx1"><mxGeometry x="70" y="124" width="400" height="20" as="geometry" /></mxCell>
        <mxCell id="m1" value="POST decide {capture_trade · DEAL-CR-9001 · $4.2M}" style="endArrow=block;html=1;fontSize=11;fontColor=#14171A;strokeColor=#6E1D24;" edge="1" parent="sx1"><mxGeometry relative="1" as="geometry"><mxPoint x="155" y="156" as="sourcePoint" /><mxPoint x="450" y="156" as="targetPoint" /></mxGeometry></mxCell>
