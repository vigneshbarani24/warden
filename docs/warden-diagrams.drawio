        <mxCell id="wit" value="witness · us-east-2 (commit quorum)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;dashed=1;fillColor=#FFFFFF;strokeColor=#147EBA;fontColor=#14171A;fontSize=10;" vertex="1" parent="a1"><mxGeometry x="840" y="290" width="200" height="40" as="geometry" /></mxCell>
        <mxCell id="tbl" value="5 tables — no FKs, UUID PKs:&lt;br&gt;org_units · authority_grants&lt;br&gt;policy_rules · decisions · ledger" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#FFFFFF;strokeColor=#147EBA;fontColor=#14171A;fontSize=11;" vertex="1" parent="a1"><mxGeometry x="785" y="360" width="310" height="100" as="geometry" /></mxCell>

