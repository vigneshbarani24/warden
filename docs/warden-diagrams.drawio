  <diagram name="3 · How the agent works" id="agentflow">
    <mxGraphModel dx="1200" dy="760" grid="0" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1180" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="g0" /><mxCell id="g1" parent="g0" />
        <mxCell id="gtitle" value="How the Warden-gated agent works — the LLM proposes, Warden decides" style="text;html=1;align=left;fontSize=16;fontStyle=1;fontColor=#14171A;" vertex="1" parent="g1"><mxGeometry x="40" y="20" width="1000" height="28" as="geometry" /></mxCell>

        <mxCell id="op" value="Operator&lt;br&gt;/agent (browser)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFFFFF;strokeColor=#232F3E;fontColor=#14171A;fontSize=12;fontStyle=1;" vertex="1" parent="g1"><mxGeometry x="60" y="250" width="170" height="60" as="geometry" /></mxCell>

        <mxCell id="loop" value="ToolLoopAgent · gpt-4.1 · lib/agents/erp-agent.ts&lt;br&gt;acts as maya.chen · /global/trading/crude/ · stopWhen 8 steps" style="rounded=1;whiteSpace=wrap;html=1;arcSize=4;fillColor=#F4F4F4;strokeColor=#B5790A;fontColor=#14171A;fontSize=11;fontStyle=1;verticalAlign=top;spacingTop=8;dashed=1;" vertex="1" parent="g1"><mxGeometry x="290" y="110" width="430" height="380" as="geometry" /></mxCell>
        <mxCell id="s1" value="1 · LLM picks a tool — captureTrade | approveSettlement | approvePayment {resource, amount}" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFFFFF;strokeColor=#232F3E;fontColor=#14171A;fontSize=11;" vertex="1" parent="g1"><mxGeometry x="310" y="160" width="390" height="46" as="geometry" /></mxCell>
        <mxCell id="s2" value="2 · tool.gatedExecute() calls Warden decide() — lib/tools/erp-tools.ts" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFFFFF;strokeColor=#232F3E;fontColor=#14171A;fontSize=11;" vertex="1" parent="g1"><mxGeometry x="310" y="222" width="390" height="44" as="geometry" /></mxCell>
        <mxCell id="sV" value="verdict?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;fontColor=#14171A;fontSize=11;" vertex="1" parent="g1"><mxGeometry x="500" y="278" width="100" height="46" as="geometry" /></mxCell>
        <mxCell id="sAllow" value="allow → action mock-executed&lt;br&gt;(no real ERP) · executed: true" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#EAF5EE;strokeColor=#1F7A4D;fontColor=#14171A;fontSize=11;" vertex="1" parent="g1"><mxGeometry x="310" y="338" width="185" height="58" as="geometry" /></mxCell>
        <mxCell id="sDeny" value="deny / escalate → HALT&lt;br&gt;agent does not act · cites reason + rule id" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#F8ECEB;strokeColor=#B0271F;fontColor=#14171A;fontSize=11;" vertex="1" parent="g1"><mxGeometry x="515" y="338" width="185" height="58" as="geometry" /></mxCell>
        <mxCell id="s4" value="3 · result returns to the loop → LLM narrates briefly → 4 · streamed to the browser (text + verdict card)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFFFFF;strokeColor=#232F3E;fontColor=#14171A;fontSize=11;" vertex="1" parent="g1"><mxGeometry x="310" y="418" width="390" height="50" as="geometry" /></mxCell>

        <mxCell id="pdp" value="Warden PDP · decide() — lib/pdp.ts&lt;br&gt;ONE Aurora DSQL txn · SELECT … FOR UPDATE&lt;br&gt;engine: authority → limit → SoD → verdict" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#F6EFE9;strokeColor=#6E1D24;fontColor=#14171A;fontSize=11;fontStyle=1;" vertex="1" parent="g1"><mxGeometry x="780" y="180" width="320" height="90" as="geometry" /></mxCell>
        <mxCell id="db" value="Aurora DSQL — writes decision row + hash-chained ledger append" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#FFFFFF;strokeColor=#147EBA;fontColor=#147EBA;fontSize=11;fontStyle=1;" vertex="1" parent="g1"><mxGeometry x="780" y="300" width="320" height="60" as="geometry" /></mxCell>
        <mxCell id="cons" value="Warden console (other tab)&lt;br&gt;polls /api/decisions + /api/ledger every 2.5s — verdicts surface live" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#FFFFFF;strokeColor=#232F3E;fontColor=#14171A;fontSize=11;" vertex="1" parent="g1"><mxGeometry x="780" y="400" width="320" height="70" as="geometry" /></mxCell>

        <mxCell id="ge0" value="POST /api/agent (UI messages, streamed back)" style="endArrow=block;html=1;fontSize=10;fontColor=#14171A;strokeColor=#232F3E;" edge="1" parent="g1" source="op" target="loop"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ge1" value="" style="endArrow=block;html=1;strokeColor=#232F3E;" edge="1" parent="g1" source="s1" target="s2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ge2" value="" style="endArrow=block;html=1;strokeColor=#232F3E;" edge="1" parent="g1" source="s2" target="sV"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ge3" value="allow" style="endArrow=block;html=1;fontSize=10;fontColor=#1F7A4D;strokeColor=#1F7A4D;" edge="1" parent="g1" source="sV" target="sAllow"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ge4" value="deny / escalate" style="endArrow=block;html=1;fontSize=10;fontColor=#B0271F;strokeColor=#B0271F;" edge="1" parent="g1" source="sV" target="sDeny"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ge5" value="decide({actor: maya.chen, actionType, resource, amount, orgPath})" style="endArrow=block;html=1;fontSize=10;fontColor=#6E1D24;strokeColor=#6E1D24;" edge="1" parent="g1" source="s2" target="pdp"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ge6" value="reads grants/SoD · seals verdict" style="endArrow=block;html=1;fontSize=10;fontColor=#147EBA;strokeColor=#147EBA;" edge="1" parent="g1" source="pdp" target="db"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ge7" value="surfaces in the other tab" style="endArrow=block;dashed=1;html=1;fontSize=10;fontColor=#14171A;strokeColor=#5A6470;" edge="1" parent="g1" source="db" target="cons"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="gnote" value="The LLM never returns the verdict. The tools call decide(); Warden's deterministic engine is the source of truth. A deny or escalate halts the agent — it does not retry or route around the control." style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#EEF1F0;strokeColor=#C9CFCD;fontColor=#14171A;fontSize=11;align=left;verticalAlign=middle;spacingLeft=12;" vertex="1" parent="g1"><mxGeometry x="60" y="520" width="1040" height="50" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>

