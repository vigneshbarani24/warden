        <mxCell id="e4" value="decision + ledger · one txn · FOR UPDATE" style="endArrow=block;startArrow=block;html=1;fontSize=10;fontColor=#147EBA;strokeColor=#147EBA;" edge="1" parent="c1" source="warden" target="dsql"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e5" value="propose action / compile policy" style="endArrow=block;dashed=1;html=1;fontSize=10;fontColor=#B5790A;strokeColor=#B5790A;" edge="1" parent="c1" source="warden" target="openai"><mxGeometry relative="1" as="geometry" /></mxCell>
