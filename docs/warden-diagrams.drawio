        <mxCell id="e1" value="POST proposed action (HTTPS / @warden/sdk)" style="endArrow=block;html=1;fontSize=10;fontColor=#14171A;strokeColor=#6E1D24;" edge="1" parent="c1" source="agent" target="warden"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e2" value="allow · deny · escalate (+reason, +rule ids)" style="endArrow=block;dashed=1;html=1;fontSize=10;fontColor=#1F7A4D;strokeColor=#1F7A4D;exitX=0.3;exitY=0;exitDx=0;exitDy=0;entryX=0.8;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="c1" source="warden" target="agent"><mxGeometry relative="1" as="geometry" /></mxCell>
