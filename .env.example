# Aurora DSQL connection (set DSQL_ENDPOINT after running `npm run provision`).
DSQL_ENDPOINT=<cluster-id>.dsql.us-east-1.on.aws
DSQL_REGION=us-east-1
AWS_REGION=us-east-1

# Region B of a multi-region cluster — required only for POST /api/demo/cross-region.
# Both endpoints are one logical, strongly-consistent DB; a revoke on A is seen on B.
# DSQL_ENDPOINT_B=<peer-cluster-id>.dsql.us-west-2.on.aws
# DSQL_REGION_B=us-west-2

# On Vercel only: the IAM role assumed via OIDC federation (no stored keys).
# Leave UNSET locally — scripts use the default AWS provider chain (~/.aws/credentials).
# AWS_ROLE_ARN=arn:aws:iam::<account-id>:role/warden-dsql

# Vercel AI Gateway (Phase 5).
# AI_GATEWAY_API_KEY=
