# ── Aurora DSQL — region A (required) ────────────────────────────────────
# Region A endpoint. From the AWS DSQL console, `aws dsql list-clusters`,
# or `npm run provision`. In prod this points at the multi-Region cluster A.
DSQL_ENDPOINT=<cluster-id>.dsql.us-east-1.on.aws
DSQL_REGION=us-east-1
# Fallback for DSQL_REGION locally. NOTE: AWS_REGION is Lambda-reserved on Vercel
# (the function never sees a value you set under it) — use DSQL_REGION there.
AWS_REGION=us-east-1

# ── Aurora DSQL — region B (only for POST /api/demo/cross-region) ─────────
# Peer endpoint of the SAME multi-Region cluster. A revoke on A is seen by the
# next read on B. From `aws dsql list-clusters --region us-west-2`.
# DSQL_ENDPOINT_B=<peer-cluster-id>.dsql.us-west-2.on.aws
# DSQL_REGION_B=us-west-2

# ── OpenAI (required for the agent + NL→policy authoring) ─────────────────
# Read by lib/ai/model.ts (gpt-4.1 / gpt-4.1-mini via @ai-sdk/openai). A direct
# key, not the Vercel AI Gateway. From https://platform.openai.com/api-keys.
OPENAI_API_KEY=sk-...

# ── AWS credentials ──────────────────────────────────────────────────────
# LOCAL: leave everything below UNSET — scripts use the default AWS provider
# chain (~/.aws/credentials).
#
# VERCEL — OIDC path (preferred, no stored keys): the IAM role assumed via
# federation. From your AWS IAM console.
# AWS_ROLE_ARN=arn:aws:iam::<account-id>:role/warden-dsql
#
# VERCEL — static-key path: the function runtime is AWS Lambda, which RESERVES
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY — values set under those names never
# reach the code. Use these NON-reserved names instead (read in lib/db.ts).
# DSQL_AWS_ACCESS_KEY_ID=AKIA...
# DSQL_AWS_SECRET_ACCESS_KEY=...
